# Environment Configuration for LMS Backend
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env file contains sensitive data and should NEVER be committed to git

# ===== DATABASE CONFIGURATION =====
DB_NAME=django_lms_db
DB_USER=lms_user
DB_PASSWORD=your_secure_db_password
DB_HOST=localhost
DB_PORT=5432

# ===== REDIS CONFIGURATION =====
REDIS_URL=redis://localhost:6379

# ===== DEVELOPMENT/PRODUCTION TOGGLE =====
USE_SQLITE_FALLBACK=False
DEBUG=False

# ===== DJANGO SETTINGS =====
SECRET_KEY=your-django-secret-key-here
DJANGO_LOG_LEVEL=INFO

# ===== EMAIL CONFIGURATION =====
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=your-email@example.com

# ===== FRONTEND CONFIGURATION =====
FRONTEND_SITE_URL=https://lmsetjendpdri.duckdns.org
BACKEND_SITE_URL=https://lmsetjendpdri.duckdns.org
REACT_APP_API_BASE_URL=https://lmsetjendpdri.duckdns.org

# ===== SECURITY SETTINGS FOR PRODUCTION =====
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===== PERFORMANCE SETTINGS =====
DATABASE_QUERY_CACHE_TIMEOUT=300
CACHE_MIDDLEWARE_SECONDS=300

# ===== FILE UPLOAD CONFIGURATION =====
FILE_UPLOAD_MAX_MEMORY_SIZE=104857600  # 100MB for large videos
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600  # 100MB for large videos

# ===== LOCAL STORAGE STRATEGY =====
USE_LOCAL_OPTIMIZATION=True
ENABLE_FILE_COMPRESSION=True
ENABLE_IMAGE_OPTIMIZATION=True
ENABLE_VIDEO_COMPRESSION=False  # Set True if ffmpeg installed

# ===== FILE SIZE LIMITS BY TYPE =====
MAX_VIDEO_FILE_SIZE=524288000    # 500MB for videos
MAX_IMAGE_FILE_SIZE=52428800     # 50MB for images
MAX_DOCUMENT_FILE_SIZE=104857600 # 100MB for documents
MAX_AUDIO_FILE_SIZE=104857600    # 100MB for audio

# ===== LOCAL STORAGE PATHS =====
MEDIA_SUBDIRS=True  # Organize files in subdirectories
BACKUP_MEDIA_FILES=True  # Enable local backup
MEDIA_BACKUP_PATH=/path/to/backup/media

# ===== DATABASE STORAGE OPTIONS =====
STORE_THUMBNAILS_IN_DB=True
STORE_SMALL_FILES_IN_DB=False  # Files < 1MB
SMALL_FILE_THRESHOLD=1048576   # 1MB threshold

# ===== PERFORMANCE OPTIMIZATION =====
ENABLE_MEDIA_CACHE=True
MEDIA_CACHE_DURATION=3600  # 1 hour cache
ENABLE_LAZY_LOADING=True

# ===== MONITORING (OPTIONAL) =====
SENTRY_DSN=your-sentry-dsn-here

# ===== CELERY CONFIGURATION =====
CELERY_BROKER_URL=redis://localhost:6379/4
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# ===== EXTERNAL API INTEGRATION (SENSITIVE) =====
# IMPORTANT: These credentials should be kept secure and never committed to git
# The following values are required for external user synchronization

# External API endpoint URL
EXTERNAL_API_URL=https://cmb.tail91813a.ts.net/api/external/users

# API authentication token - KEEP THIS SECRET!
EXTERNAL_API_TOKEN=your-api-token-here

# XSRF token for API authentication - KEEP THIS SECRET!
# This may need to be refreshed periodically if the external API invalidates it
EXTERNAL_API_XSRF_TOKEN=your-xsrf-token-here

# Session cookie for API authentication - KEEP THIS SECRET!
# This may need to be refreshed periodically if the external API session expires
EXTERNAL_API_SESSION_COOKIE=your-session-cookie-here

# API request timeout in seconds
EXTERNAL_API_TIMEOUT=30

# ===== SECURITY NOTES =====
# 1. NEVER commit .env file to git - it's in .gitignore for a reason
# 2. Use .env.example to document required variables (without sensitive values)
# 3. In production, use proper secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Rotate API tokens regularly
# 5. Use different tokens for development and production environments
# 6. Monitor API token usage for suspicious activity
