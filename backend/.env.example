# ===========================
# Django Settings
# ===========================
SECRET_KEY=django-insecure-your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,lmsetjendpdri.duckdns.org

# ===========================
# Frontend & Backend URLs
# ===========================
FRONTEND_SITE_URL=http://localhost:5173
BACKEND_SITE_URL=http://localhost:8000

# ===========================
# Database Configuration
# ===========================
# PostgreSQL (Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=lmsdb
DB_USER=lmsuser
DB_PASSWORD=lmspassword123
DB_HOST=localhost
DB_PORT=5432

# ===========================
# Redis Configuration
# ===========================
# Redis Cache (Docker)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================
# Email Configuration (Optional)
# ===========================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ===========================
# Google OAuth Configuration
# ===========================
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/login

# ===========================
# Nusa DPD SSO Configuration
# ===========================
NUSA_DPD_SSO_URL=https://nusadpd.duckdns.org/sso/
NUSA_DPD_SECRET_KEY=your-nusa-dpd-secret-key

# ===========================
# JWT Configuration
# ===========================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ===========================
# Logging Configuration
# ===========================
LOG_LEVEL=INFO
LOG_FILE=django.log
