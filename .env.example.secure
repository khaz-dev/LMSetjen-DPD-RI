# ============================================================================
# 🔒 SECURITY HARDENED ENVIRONMENT CONFIGURATION
# LMSetjen DPD RI - Penetration Test Preparation
# ============================================================================
#
# CRITICAL: This file documents ALL required environment variables.
# Never commit actual secrets to version control.
# Use CI/CD secrets manager or secure .env file on server.
#
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS - PRODUCTION SECURITY
# ============================================================================

# 🔒 CRITICAL: Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Must be a strong, random string (at least 50 characters)
SECRET_KEY=your-super-secret-key-change-this-in-production

# 🔒 CRITICAL: Set to False in production ALWAYS
DEBUG=False

# 🔒 CRITICAL: Comma-separated list of allowed hosts for production
# Example: lms.dpd.go.id,www.lms.dpd.go.id,lms.khaz.app
ALLOWED_HOSTS=localhost,127.0.0.1,lms.dpd.go.id,lms.khaz.app

# ============================================================================
# DATABASE CONFIGURATION - POSTGRESQL
# ============================================================================

# 🔒 CRITICAL: All database credentials from environment variables only
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your-strong-database-password-min-20-chars
DB_HOST=your-database-host.example.com
DB_PORT=5432

# 🔒 SECURITY: Use SSL for database connections in production
# Options: disable (dev), allow (accepts SSL), prefer (prefer SSL), require (force SSL)
DB_SSLMODE=require

# Alternative: Use DATABASE_URL instead of individual settings
# Format: postgresql://user:password@host:port/dbname?sslmode=require
# DATABASE_URL=postgresql://user:password@postgres-host:5432/lmsdb?sslmode=require

# ============================================================================
# REDIS CACHE & SESSION CONFIGURATION
# ============================================================================

# 🔒 CRITICAL: Redis password for authentication
REDIS_PASSWORD=your-strong-redis-password-min-20-chars
REDIS_URL=redis://:your-strong-redis-password@redis-host:6379/0

# Optional Redis configuration
REDIS_HOST=redis-host.example.com
REDIS_PORT=6379

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SendGrid API key for email delivery
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Email sender address
FROM_EMAIL=noreply@lms.dpd.go.id

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend URL for email links, redirects, CORS
FRONTEND_SITE_URL=https://lms.khaz.app

# Vite API base URL (used by frontend)
VITE_API_BASE_URL=https://lms-be.khaz.app/api

# Backend site URL
BACKEND_SITE_URL=https://lms-be.khaz.app

# ============================================================================
# CORS & CSRF SECURITY SETTINGS
# ============================================================================

# Comma-separated list of allowed frontend origins for CORS
# Must match the actual frontend domain(s)
CORS_ALLOWED_ORIGINS=https://lms.khaz.app,https://lms.dpd.go.id

# Allow all origins - NEVER use in production (security risk)
CORS_ALLOW_ALL_ORIGINS=False

# Comma-separated list of trusted origins for CSRF validation
CSRF_TRUSTED_ORIGINS=https://lms.khaz.app,https://lms-be.khaz.app,https://lms.dpd.go.id

# ============================================================================
# SSL/TLS & HTTPS CONFIGURATION
# ============================================================================

# 🔒 SECURITY: Enable HTTPS redirect in production
SECURE_SSL_REDIRECT=True

# 🔒 SECURITY: Trust X-Forwarded-Proto header from nginx/reverse proxy
# Only use if you have a reverse proxy in front (like nginx)
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True

# Cookie security settings
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ============================================================================
# GOOGLE OAUTH CONFIGURATION (OPTIONAL)
# ============================================================================

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-do-not-share
GOOGLE_OAUTH_REDIRECT_URI=https://lms.khaz.app/auth/google/callback

# ============================================================================
# SSO (SINGLE SIGN-ON) CONFIGURATION
# ============================================================================

# 🔒 CRITICAL: Secret key for verifying SSO tokens from external provider
SSO_SECRET_KEY=your-sso-secret-key-for-token-verification

# SSO token algorithm (usually HS256)
SSO_ALGORITHM=HS256

# ============================================================================
# EXTERNAL API CONFIGURATION
# ============================================================================

# External API for employee/pegawai data (CMB DPD RI)
EXTERNAL_API_BASE_URL=https://cmb.dpd.go.id
EXTERNAL_API_USERS_ENDPOINT=/api/pegawai
EXTERNAL_API_TOKEN=your-external-api-token-if-required
EXTERNAL_API_TIMEOUT=30

# SSL verification for external API (use True in production)
EXTERNAL_API_VERIFY_SSL=True

# CA bundle path for SSL verification (if using custom certificates)
EXTERNAL_API_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Max file upload sizes (in bytes)
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760      # 10MB
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880       # 5MB

# Max video file size
MAX_VIDEO_FILE_SIZE=524288001             # 500MB

# Max image file size
MAX_IMAGE_FILE_SIZE=52428800              # 50MB

# Max document file size
MAX_DOCUMENT_FILE_SIZE=104857600          # 100MB

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Django log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# Security log level (for security audit logging)
SECURITY_LOG_LEVEL=WARNING

# ============================================================================
# RATE LIMITING / THROTTLING
# ============================================================================

# Anonymous user request rate limit
ANON_THROTTLE_RATE=100/hour

# Authenticated user request rate limit
USER_THROTTLE_RATE=1000/hour

# Login attempt limit
LOGIN_ATTEMPT_LIMIT=5

# Login attempt timeout (seconds)
LOGIN_ATTEMPT_TIMEOUT=300

# ============================================================================
# DEPLOYMENT SPECIFIC
# ============================================================================

# Environment type (development, staging, production)
ENVIRONMENT=production

# Set to True to use SENTRY for error tracking
USE_SENTRY=False
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# SECURITY HEADERS & POLICIES
# ============================================================================

# Strict Transport Security (HSTS) max age in seconds
# 31536000 = 1 year
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============================================================================
# DOCKER SPECIFIC (if using Docker)
# ============================================================================

# Database host for Docker container communication
# Use: postgres (service name) for Docker Compose
# Use: host.docker.internal for Windows/Mac host access
DB_HOST=postgres

# Redis host for Docker container communication
REDIS_HOST=redis
REDIS_PORT=6379

