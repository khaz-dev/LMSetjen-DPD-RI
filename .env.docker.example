# ============================================
# Docker Environment Configuration Template
# LMSetjen DPD RI - Learning Management System
# ============================================
# Copy this file to .env.docker and update with your values

# ============================================
# Database Configuration - PostgreSQL
# ============================================
DB_NAME=django_lms_db
DB_USER=lms_user
DB_PASSWORD=your_secure_database_password_here
DB_HOST=postgres
DB_PORT=5432

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_PASSWORD=your_secure_redis_password_here

# ============================================
# Django Configuration
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
DEBUG=False
DJANGO_LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ============================================
# URLs Configuration
# ============================================
FRONTEND_SITE_URL=http://localhost
BACKEND_SITE_URL=http://localhost:8000
REACT_APP_API_BASE_URL=http://localhost:8000

# ============================================
# Email Configuration (SendGrid)
# ============================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=noreply@your-domain.com

# ============================================
# Security & Performance
# ============================================
USE_SQLITE_FALLBACK=False
CONN_MAX_AGE=300

# ============================================
# External API Configuration - CMB Integration
# ============================================
# API endpoint for syncing user data from external systems
# Obtain credentials from your CMB administrator
CMB_API_URL=https://cmb.tail91813a.ts.net
CMB_API_TOKEN=your-cmb-api-token-here
CMB_XSRF_TOKEN=your-cmb-xsrf-token-here
CMB_SESSION_COOKIE=your-cmb-session-cookie-here
CMB_API_TIMEOUT=30

# ============================================
# Production Settings (for docker-compose.prod.yml)
# ============================================
# Uncomment and configure for production deployment

# SSL Certificate paths
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Domain configuration
# DOMAIN=your-domain.com
# WWW_DOMAIN=www.your-domain.com

# Backup configuration
# BACKUP_ENABLED=True
# BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=30

# ============================================
# Development Settings
# ============================================
# Only for development environment
# COMPOSE_PROJECT_NAME=lms_dev

