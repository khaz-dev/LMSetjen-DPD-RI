# LMSetjen DPD RI - Environment Configuration Template
# Copy this file to .env and fill in your values
# 
# For Local Development: Set MODE=development, DEBUG=True, use localhost URLs
# For Staging/Production: Set MODE=staging/production, DEBUG=False, use domain URLs
#
# DO NOT COMMIT SECRETS TO GIT - This file should only contain placeholders

# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT MODE (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════
# Options: development | staging | production
MODE=development

# ═══════════════════════════════════════════════════════════════════════════════
# DJANGO SECURITY SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-to-production-key
DEBUG=True
ALLOWED_HOSTS=lms.khaz.app,www.lms.khaz.app,lms-be.khaz.app,165.245.191.216,localhost,127.0.0.1,django,lms
DJANGO_LOG_LEVEL=INFO
USE_SSL=False

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
DB_ENGINE=django.db.backends.postgresql
DB_NAME=lmsdb
DB_USER=lms_user
DB_PASSWORD=change-to-secure-password
DB_HOST=host.docker.internal
DB_PORT=5432

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_HOST=redis
REDIS_PORT=6381
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6381/0

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND & BACKEND URLS
# ═══════════════════════════════════════════════════════════════════════════════
# For development:
#   FRONTEND_SITE_URL=http://localhost:5174
#   BACKEND_SITE_URL=http://localhost:8001
#   VITE_API_BASE_URL=http://localhost:8001
#
# For staging:
#   FRONTEND_SITE_URL=https://lms.khaz.app
#   BACKEND_SITE_URL=https://lms.khaz.app
#   VITE_API_BASE_URL=https://lms.khaz.app
FRONTEND_SITE_URL=http://localhost:5174
BACKEND_SITE_URL=http://localhost:8001
VITE_API_BASE_URL=http://localhost:8001

# ═══════════════════════════════════════════════════════════════════════════════
# CORS & CSRF CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# For development: localhost values are fine
# For production: set to your domain
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://lms.khaz.app
CSRF_TRUSTED_ORIGINS=http://localhost:8001,http://localhost:5174,http://127.0.0.1:8001,http://127.0.0.1:5174,https://lms.khaz.app

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5174/login
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# Leave empty to use console backend (development)
# Set to SendGrid API key for production email
SENDGRID_API_KEY=
FROM_EMAIL=noreply@localhost

# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
EXTERNAL_API_BASE_URL=https://cmb.dpd.go.id
EXTERNAL_API_USERS_ENDPOINT=/api/pegawai
EXTERNAL_API_TOKEN=your-api-token-here
# Optional fallback token. Used only when primary token returns 401/403.
EXTERNAL_API_TOKEN_FALLBACK=
# Optional additional token candidates, separated by || or newline.
# Example: token1||token2
EXTERNAL_API_TOKEN_CANDIDATES=
EXTERNAL_API_TOKEN_HEADER=X-API-TOKEN
# Auto-generate encrypted token variants (v1.aes:...) from raw tokens.
EXTERNAL_API_TOKEN_ENABLE_ENCRYPTED_CANDIDATES=True
# Uses the same pattern you shared: encryptTokenForHeader(API_TOKEN, { salt: API_TOKEN })
EXTERNAL_API_TOKEN_ENCRYPT_WITH_SELF_SALT=True
# Optional fixed salt; leave empty unless upstream explicitly requires static salt.
EXTERNAL_API_TOKEN_ENCRYPTION_SALT=
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_QUERY_ALL=False
# SSL Verification for external API
# - Set to True (default) to verify SSL certificates using system CA bundle
# - Set to False only for temporary development/testing (NOT for production)
# - DigiCert CA certificate is automatically included in Docker image
EXTERNAL_API_VERIFY_SSL=True
# Optional: custom CA bundle path for self-signed or internal certificates
# Leave empty to use system CA certificates (/etc/ssl/certs/ca-certificates.crt)
# Set to custom path if needed (e.g., /app/certs/custom-ca.pem)
EXTERNAL_API_CA_BUNDLE=
