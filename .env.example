# ============================================
# AWS Deployment Environment Variables
# LMSetjen DPD RI - Learning Management System
# ============================================

# Django Settings
SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=False
DJANGO_LOG_LEVEL=INFO

# Database Configuration (PostgreSQL)
DB_NAME=lms_db
DB_USER=lms_user
DB_PASSWORD=your_secure_database_password_here
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# Allowed Hosts (comma-separated)
# Add your EC2 public IP and domain name
ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-ip-here,your-domain.com

# CORS Settings (comma-separated frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://your-ec2-ip-here,https://your-domain.com

# Site URLs
FRONTEND_SITE_URL=http://your-ec2-ip-here
BACKEND_SITE_URL=http://your-ec2-ip-here:8000

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@yourdomain.com

# AWS S3 Configuration (Optional - for media files)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_STORAGE_BUCKET_NAME=your-bucket-name-here
AWS_S3_REGION_NAME=us-east-1

# ============================================
# External API Configuration - CMB Integration
# ============================================
# API endpoint for syncing user data from external systems
CMB_API_URL=https://cmb.tail91813a.ts.net
CMB_API_TOKEN=your-cmb-api-token-here
CMB_XSRF_TOKEN=your-cmb-xsrf-token-here
CMB_SESSION_COOKIE=your-cmb-session-cookie-here
CMB_API_TIMEOUT=30

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=7

