# Frontend .gitignore for React + Vite

# ===================================
# DEPENDENCIES
# ===================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===================================
# BUILD OUTPUT
# ===================================
dist/
dist-ssr/
build/
*.local

# ===================================
# VITE
# ===================================
# Vite cache
.vite/
vite.config.js.timestamp-*

# ===================================
# ENVIRONMENT VARIABLES
# ===================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ===================================
# TESTING
# ===================================
coverage/
.nyc_output/
*.lcov

# Test results
test-results/
junit.xml

# ===================================
# IDE & EDITORS
# ===================================
# VS Code
.vscode/*
!.vscode/extensions.json
*.code-workspace

# IntelliJ
.idea/
*.iml
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ===================================
# OPERATING SYSTEM
# ===================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ===================================
# LOGS
# ===================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===================================
# TEMPORARY FILES
# ===================================
*.tmp
*.temp
.cache/
.parcel-cache/

# ===================================
# PACKAGE MANAGERS
# ===================================
# Yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# pnpm
.pnpm-store/

# ===================================
# REACT / NEXT.JS (if needed)
# ===================================
# Next.js
.next/
out/

# ===================================
# STORYBOOK
# ===================================
storybook-static/

# ===================================
# MISCELLANEOUS
# ===================================
# Debug files
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# ===================================
# DOCUMENTATION (drafts)
# ===================================
DRAFT_*.md
TODO_*.md

# Internal documentation (keep final docs)
FIXES_APPLIED.md
QUICK_FIX_REFERENCE.md
VIDEO_COMPRESSION_GUIDE.md

# ===================================
# DEVELOPMENT / TESTING
# ===================================
# Test files (if you want to exclude test directory)
# src/views/test/
# src/**/cursor-test.css
# src/**/*.test.{js,jsx}
# src/**/*.spec.{js,jsx}

# ===================================
# SECURITY
# ===================================
# Never commit sensitive data
*.pem
*.key
*.crt
secrets.json
credentials.json
service-account-key.json
.vercel
