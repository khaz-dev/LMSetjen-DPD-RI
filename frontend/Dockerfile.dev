# ============================================
# Development Dockerfile for React Frontend
# Uses Vite dev server (no Nginx)
# ============================================

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package.json ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy frontend source code  
COPY frontend .

# Expose Vite dev server port
EXPOSE 5174

# Note: Removed health check - frontend is dev server (always ready)
# Backend has health check which is what matters

# Start Vite dev server with explicit 0.0.0.0 host binding
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
